# PostgreSQL Database Configuration
# Copy this file to .env and update with your local PostgreSQL credentials

# Option 1: Full DATABASE_URL (recommended)
DATABASE_URL=postgresql://username:password@localhost:5432/stock_analysis

# Option 2: Individual connection parameters
PGHOST=localhost
PGPORT=5432
PGUSER=your_username
PGPASSWORD=your_password
PGDATABASE=stock_analysis

# Ollama (local LLM) configuration for AI-powered stock analysis
# No API key required - ensure Ollama is running (e.g. ollama serve)
# Default: http://localhost:11434 with model gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b

# Ollama Analysis page model
# Example:
# OLLAMA_ANALYSIS_MODEL=gemma3:4b
# If not set, defaults to gemma3:4b

